# ConfiguraĂ§Ăµes Globais
LOG_LEVEL=info

# Infraestrutura (Local)
KAFKA_BROKERS=localhost:9092
REDIS_ADDR=localhost:6379
DATABASE_URL=postgres://staff_eng:super_secret_password@localhost:5432/ledger_db?sslmode=disable

# Infraestrutura (Docker InterpolaĂ§Ă£o - Opcional)
# DOCKER_KAFKA_BROKERS=kafka:29092
# DOCKER_REDIS_ADDR=redis:6379

# Credenciais de Banco (Usadas pelo Docker)
DB_USER=staff_eng
DB_PASSWORD=super_secret_password
DB_NAME=ledger_db

# TĂ³picos Kafka
KAFKA_TOPIC=transactions
NOTIFICATION_TOPIC=notifications

# Grupos de Consumo
KAFKA_GROUP_ID=ledger-core-group

# Portas dos ServiĂ§os (Host)
GW_PORT=8080
BACKOFFICE_PORT=8081
CORE_PORT=8082
NOTIF_PORT=8083
RECON_PORT=8084

# Monitoramento (Prometheus, Alertmanager, Grafana)
PROMETHEUS_PORT=9090
ALERTMANAGER_PORT=9093
GRAFANA_PORT=3000

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GF_USERS_ALLOW_SIGN_UP=false

# Alertas - Slack
SLACK_WEBHOOK_URL=

# Alertas - PagerDuty
PAGERDUTY_SERVICE_KEY=

# Alertas - Email
ALERT_EMAIL=admin@example.com
ALERT_FROM_EMAIL=alertmanager@example.com
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# Tópicos do Kafka
KAFKA_INIT_TOPICS=transactions,notifications

